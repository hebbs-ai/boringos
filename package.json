{
  "name": "boringos",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env.local scripts/dev-server.mjs",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter @boringos/db generate",
    "db:migrate": "pnpm --filter @boringos/db migrate",
    "pack:modules": "node scripts/pack-modules.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "pnpm -r build && changeset publish"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@boringos/agent": "workspace:*",
    "@boringos/connector-google": "workspace:*",
    "@boringos/connector-slack": "workspace:*",
    "@boringos/core": "workspace:*",
    "@boringos/db": "workspace:*",
    "@boringos/module-sdk": "workspace:*",
    "@changesets/cli": "^2.30.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    }
  }
}
