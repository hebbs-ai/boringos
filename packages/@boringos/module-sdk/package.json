{
  "name": "@boringos/module-sdk",
  "version": "0.8.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pack-hebbsmod": "./dist/cli/pack-hebbsmod.js",
    "sign-hebbsmod": "./dist/cli/sign-hebbsmod.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "LGPL-3.0-or-later",
  "dependencies": {
    "@boringos/shared": "workspace:*",
    "archiver": "^7.0.1",
    "esbuild": "^0.25.0",
    "yauzl": "^3.2.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@boringos/memory": "^0.1.9",
    "@boringos/drive": "^0.1.9"
  },
  "peerDependenciesMeta": {
    "@boringos/memory": {
      "optional": true
    },
    "@boringos/drive": {
      "optional": true
    }
  },
  "devDependencies": {
    "@boringos/drive": "workspace:*",
    "@boringos/memory": "workspace:*",
    "@types/archiver": "^6.0.2",
    "@types/node": "^22.0.0",
    "@types/yauzl": "^2.10.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "description": "Module SDK — types for the Skills + Tools + Modules architecture.",
  "repository": {
    "type": "git",
    "url": "https://github.com/BoringOS-dev/boringos.git"
  }
}
