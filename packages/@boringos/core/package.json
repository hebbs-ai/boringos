{
  "name": "@boringos/core",
  "version": "0.4.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/modules','dist/modules',{recursive:true,filter:(p)=>p.endsWith('.md')||require('fs').statSync(p).isDirectory()})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@boringos/agent": "workspace:*",
    "@boringos/connector-google": "workspace:*",
    "@boringos/connector-slack": "workspace:*",
    "@boringos/db": "workspace:*",
    "@boringos/drive": "workspace:*",
    "@boringos/memory": "workspace:*",
    "@boringos/module-sdk": "workspace:*",
    "@boringos/pipeline": "workspace:*",
    "@boringos/runtime": "workspace:*",
    "@boringos/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "better-auth": "^1.6.0",
    "hono": "^4.7.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "description": "Application host — the entry point for BoringOS",
  "repository": {
    "type": "git",
    "url": "https://github.com/BoringOS-dev/boringos.git"
  },
  "homepage": "https://boringos.dev",
  "author": "BoringOS Contributors",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "boringos",
    "agentic",
    "ai-agents",
    "framework"
  ]
}
