{
  "name": "@boringos/agent",
  "version": "0.1.8",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/personas','dist/personas',{recursive:true,filter:(p)=>!p.endsWith('.ts')})\"",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@boringos/shared": "workspace:*",
    "@boringos/runtime": "workspace:*",
    "@boringos/memory": "workspace:*",
    "@boringos/db": "workspace:*",
    "@boringos/drive": "workspace:*",
    "@boringos/pipeline": "workspace:*",
    "@boringos/module-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  },
  "description": "Agent execution engine — context pipeline, wakeups, personas, budget",
  "repository": {
    "type": "git",
    "url": "https://github.com/BoringOS-dev/boringos.git"
  },
  "homepage": "https://boringos.dev",
  "author": "BoringOS Contributors",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "boringos",
    "agentic",
    "ai-agents",
    "framework"
  ]
}
